# --- Generation provider ---
# Options: "hf-inference" (default) or "openai"
GENERATION_PROVIDER="hf-inference"

# --- Scraper security ---
# Comma-separated domain allowlist. Scraping is blocked unless you set this.
# Subdomains are NOT allowed by default. Use domains (or full URLs; they’ll be normalized).
# Example: "docs.python.org, huggingface.co"
ALLOWED_DOMAINS=""
ALLOW_SUBDOMAINS="false"
MAX_REDIRECTS="3"

# --- HuggingFace API (used when GENERATION_PROVIDER starts with "hf") ---
HF_TOKEN="YOUR_HF_TOKEN"

# --- OpenAI API (used when GENERATION_PROVIDER="openai") ---
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"

# --- Logging ---
LOG_FILE="logs/cortex.log"
LOG_LEVEL="INFO"
LOG_MAX_BYTES="1000000"
LOG_BACKUPS="3"

# --- Query expansion ---
USE_QUERY_EXPANSION=false
